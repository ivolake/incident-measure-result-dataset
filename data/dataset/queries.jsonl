{"query_id":"q_vcdb_0199fef0_3636_4f0f_8a7b_6082e2774db5","source_id":"src_vcdb_validated_query","query_text":"The New York Times' computer system was hacked after Chinese government officials warned the Times about consequences for investigating the wealth of government family members. The Times began monitoring its system closely on October 24 and noticed unusual activity on October 25 when an article about the wealth of a Chinese official's family was published. The breach began on September 13 and was allowed to continue until January so that the hackers' behavior could be studied. It appears that the passwords of every Times employee were compromised and 53 Times employees had their personal computers accessed. The 53 employees were located outside of the United States and appear to have been the ones who may have covered the Chinese stories.","query_values":{"external_query_scope":"source_extracted_external_observed_situation"},"query_origin":"source_extracted_incident_summary","attack_refs":[],"stripped_recommendation_text":true,"contains_recommendation_text":false,"identifier_fields":{"incident_id":"0199FEF0-3636-4F0F-8A7B-6082E2774DB5","action_keys":"hacking"},"leakage_notes":null,"text_provenance":{"text_origin":"normalized_verbatim","source_hash":"c50735879bff9c49b1a48777d8a0a4daad1e574334903606b7433ebe4b7751d6","source_locator":"https://raw.githubusercontent.com/vz-risk/VCDB/master/data/json/validated/0199FEF0-3636-4F0F-8A7B-6082E2774DB5.json#summary","source_field":"summary","normalization_steps":["whitespace_normalization"],"semantic_paraphrase_forbidden":true}}
